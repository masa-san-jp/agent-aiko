{
  "name": "@agent-aiko/codex",
  "version": "0.1.0",
  "description": "Codex 版 Agent-Aiko — codex app-server 経由で ChatGPT サブスク上に Aiko 人格を載せる対話シェル",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "aiko": "dist/aiko-shell.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/aiko-shell.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: TBD（Phase 7 で eslint 等を導入予定）' && exit 0",
    "test": "echo 'test: TBD（Phase 2 以降で vitest/node:test を導入予定）' && exit 0",
    "schema:generate": "codex app-server generate-ts --out src/codex-schema",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {},
  "homepage": "https://github.com/masa-san-jp/Agent-Aiko/tree/main/codex",
  "repository": {
    "type": "git",
    "url": "https://github.com/masa-san-jp/Agent-Aiko.git",
    "directory": "codex"
  },
  "license": "MIT"
}
