{
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git pull *)",
      "Bash(git clone *)",
      "Bash(git -C ../Agent-Lab *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/template-check.sh",
            "if": "Bash(git push *)"
          }
        ]
      }
    ]
  }
}
